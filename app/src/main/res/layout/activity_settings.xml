<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- ── Server Domain Card ── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="16dp"
                    android:background="@color/teal_primary"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Server Domain"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/domainValueTv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Not configured"
                    android:textSize="13sp"
                    android:textColor="@color/text_hint"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:layout_marginEnd="12dp"/>

                <Button
                    android:id="@+id/domainEditBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Edit"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_confirm"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── Service List Card ── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Column Headers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@drawable/bg_gradient_header"
                android:paddingStart="14dp"
                android:paddingEnd="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SERVICE"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.08"/>

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:text="PIN"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:letterSpacing="0.06"/>

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="SIM"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:letterSpacing="0.06"/>

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="STATUS"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:letterSpacing="0.06"/>

                <View
                    android:layout_width="48dp"
                    android:layout_height="1dp"/>

            </LinearLayout>

            <!-- Rows -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/serviceListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </ScrollView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
