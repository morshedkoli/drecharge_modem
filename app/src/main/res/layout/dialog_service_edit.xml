<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Dialog Header (gradient) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_header"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center">

        <TextView
            android:id="@+id/dialogServiceTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.02"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure service settings"
            android:textSize="12sp"
            android:textColor="@color/teal_light"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- Form body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Status row label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Service Status"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/dialogStatusRg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/dialogActiveRb"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Active"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/teal_primary"/>

            <RadioButton
                android:id="@+id/dialogInactiveRb"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Inactive"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/teal_primary"/>
        </RadioGroup>

        <!-- SIM slot label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SIM Slot"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/dialogSimRg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/dialogSim1Rb"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SIM 1"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/teal_primary"/>

            <RadioButton
                android:id="@+id/dialogSim2Rb"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SIM 2"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/teal_primary"/>
        </RadioGroup>

        <!-- Phone Number -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/dialogNumberEt"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="e.g. 01XXXXXXXXX"
            android:inputType="phone"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@drawable/bg_rounded_input"
            android:layout_marginBottom="14dp"/>

        <!-- PIN -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PIN"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/dialogPinEt"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Enter PIN"
            android:inputType="numberPassword"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@drawable/bg_rounded_input"
            android:layout_marginBottom="20dp"/>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/dialogCancelBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_cancel"
                android:layout_marginEnd="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <Button
                android:id="@+id/dialogUpdateBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Save"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_confirm"
                android:layout_marginStart="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>
