<?xml version="1.0" encoding="utf-8"?>
<layout>

    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        tools:context=".MainActivity">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="dRecharge Modem"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/homeSubtitleTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Home shows live status and transaction logs. Configure services from Settings." />

            <Button
                android:id="@+id/homeSettingsBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Open Settings" />

            <LinearLayout
                android:id="@+id/simId1Layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/sim1Status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="SIM 1 OFFLINE"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/Sim1Layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/sim1Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SIM 1" />

                    <TextView
                        android:id="@+id/getBal1Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Balance: -" />

                    <TextView
                        android:id="@+id/pin1Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="PIN: -" />

                    <TextView
                        android:id="@+id/minIntrval1Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Interval: -" />

                    <TextView
                        android:id="@+id/minBal1Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Balance Limit: -" />

                    <Switch
                        android:id="@+id/status1Sw"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:clickable="false"
                        android:focusable="false"
                        android:text="Service enabled" />

                    <Switch
                        android:id="@+id/pwLoadSim1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <Spinner
                        android:id="@+id/service1Sp"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/sim1SettingImg"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/receivedRq1Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/sendReq1Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Recent activity"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/sim1ResutlRv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:minHeight="120dp"
                        android:text="No activity yet." />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/simId2Layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/sim2Status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="SIM 2 OFFLINE"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/Sim2Layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/sim2Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SIM 2" />

                    <TextView
                        android:id="@+id/getBal2Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Balance: -" />

                    <TextView
                        android:id="@+id/pin2Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="PIN: -" />

                    <TextView
                        android:id="@+id/minIntrval2Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Interval: -" />

                    <TextView
                        android:id="@+id/minBal2Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Balance Limit: -" />

                    <Switch
                        android:id="@+id/status2Sw"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:clickable="false"
                        android:focusable="false"
                        android:text="Service enabled" />

                    <Switch
                        android:id="@+id/pwLoadSim2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <Spinner
                        android:id="@+id/service2Sp"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/sim2SettingImg"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/receivedRq2Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/sendReq2Tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Recent activity"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/sim2ResutlRv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:minHeight="120dp"
                        android:text="No activity yet." />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</layout>
